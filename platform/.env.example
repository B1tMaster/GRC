DEEPSEEK_API_KEY="sk-"
DEEPSEEK_BASE_URL="https://api.deepseek.com"
QWEN_API_KEY=""
QWEN_BASE_URL="https://dashscope-intl.aliyuncs.com/compatible-mode/v1"
OPENAI_API_KEY=""

DATABASE_URI="postgresql://postgres:postgres@localhost:5473/evonix_grc"

NEXT_PUBLIC_SERVER_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_REDIRECT=/documents
PAYLOAD_SECRET=41036556e3dc76de107ac740

# Langfuse — use cloud.langfuse.com for production, localhost:2999 for local dev
LANGFUSE_SECRET_KEY="sk-lf-..."
LANGFUSE_PUBLIC_KEY="pk-lf-..."
LANGFUSE_HOST="https://cloud.langfuse.com"

REDIS_URL="redis://localhost:6377"

# MinIO Client Configuration
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=strong-password-here
MINIO_BUCKET_NAME=default-bucket

FILES_TEMP_DIR=./temp
ZEROX_SERVICE_URL=http://localhost:3001

LANGFUSE_ENABLED=true